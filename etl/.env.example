# Cloudflare R2 credentials for the archival pipeline (see etl/etl/r2.py).
# Copy to `.env` (gitignored) and fill in real values -- never commit `.env`.
#
# R2Store.from_env() reads these directly from the process environment;
# export them (e.g. `set -a; source etl/.env; set +a`) before running
# `etl archive` or `etl sync-r2`.

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Optional: public base URL prefix for archived_url (e.g. a custom domain
# or the bucket's public r2.dev URL). Falls back to https://<bucket>.r2.dev
# when unset.
R2_PUBLIC_BASE_URL=
